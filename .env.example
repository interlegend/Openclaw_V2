# ==========================================
# OpenClaw Public Release Environment Template
# ==========================================

# --- TELEGRAM CONFIGURATION ---
# The API token for your bot (get it from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram User IDs allowed to use the bot.
# The FIRST ID in this list will receive all proactive admin notifications.
TELEGRAM_ALLOWED_USERS=your_telegram_id_here

# --- LLM API KEYS ---
# Primary model provider (Groq recommended for speed/memory)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Other providers
OPENAI_API_KEY=sk-your_openai_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
GOOGLE_API_KEY=AIza_your_google_api_key_here

# --- RUNTIME SETTINGS ---
# Optional: Set a password to lock/unlock the bot via command
BOT_PASSWORD=

# Default model to use for the session
PRIMARY_MODEL=llama-3.3-70b-versatile

# --- ADVANCED ---
# Internal API gateway token (used for multi-agent communication)
GATEWAY_TOKEN=generate_a_random_secure_token_here
